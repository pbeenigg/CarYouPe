# Docker Compose 解析 docker-compose.yml 时读取的变量（仅限此目录下的 .env 文件）
# 复制为 .env 后，compose 才能正确替换 image 标签，例如: caryoupe-website:${VERSION:-latest}
# 注意：env_file: .env.local 是给容器内用的，不会参与 compose 文件本身的变量替换
VERSION=1.0.0


# 邮件服务配置（推荐使用 SMTP）
# 如果使用 SMTP，请配置以下变量
SMTP_HOST=smtp.163.com
SMTP_PORT=994
SMTP_SECURE=true
SMTP_USER=caryoupe@163.com
SMTP_PASS=NKgbp86KPRhWhZKz

# 内部通知邮件接收者（多个邮箱用逗号分隔）
INTERNAL_EMAILS=caryoup@163.com,pbeenig@hotmail.com,1738750963@qq.com
